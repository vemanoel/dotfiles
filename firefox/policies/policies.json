{
	"policies": {
		"DownloadDirectory": "${home}/Downloads/firefox",
		"PromptForDownloadLocation": false,
		"SearchEngines": {
			"Default": "Google"
		},
		"NewTabPage": false,
		"Homepage": {
			"Locked": true,
			"URL": "chrome://browser/content/blanktab.html",
			"StartPage": "none",
			"Additional": []
		},
		"PictureInPicture": {
			"Enabled": false,
			"Locked": true
		},
		"HardwareAcceleration": true,
		"DisableTelemetry": true,
		"SanitizeOnShutdown": {
			"SiteSettings": false,
			"Cache": false,
      		"Sessions": false,
			"Cookies": false,
			"FormData": false,
			"History": true,
			"Locked": true
		},
		"DisplayBookmarksToolbar": "never",
		"PopupBlocking": {
			"Allow": [],
			"Default": false,
			"Locked": true
		},
		"ExtensionSettings": {
			"uBlock0@raymondhill.net": {
				"install_url": "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi",
				"installation_mode": "force_installed"
			},
			"sponsorBlocker@ajay.app": {
				"install_url": "https://addons.mozilla.org/firefox/downloads/latest/sponsorblock/latest.xpi",
				"installation_mode": "force_installed"
			}
		},
		"Preferences": {
	      "ui.systemUsesDarkTheme": {
	        "Value": 1,
	        "Status": "default"
	        "Type": "number"
	      },
	      "ui.systemUsesDarkTheme": {
	        "Value": 1,
	        "Status": "default"
	        "Type": "number"
	      },
	      "browser.theme.content-theme": {
	        "Value": 0,
	        "Status": "default"
	        "Type": "number"
	      },
	      "browser.theme.toolbar-theme": {
	        "Value": 0,
	        "Status": "default"
	        "Type": "number"
	      }
	    }
	}
}
